# execFile() 
>> This is used to execut any  executable files, It has no shell, so it is more secure.

syntax: 
const {execFile } = require('child_process');
execFile(file, args, options, callback);

const { execFile } = require('child_process');

execFile('node', ['app.js'], ( error, stdout, stderr) => {
  if (error ) {
    console.error(error);
  return ;
}
console.log(stdout);
});


# spawn() :
>> It has streaming power , it is best for the large data, real-Time, output

syntax: 
const { spawn } = require('child_process');
const child = spawn (command, args, options);


const { spawn } = require('child_process');

const child = spawn('ls', ['-l']);

child.stdout.on('data', (data) => {
  console.log(`Output: ${data}`);
});

child.stderr.on('data', (data) => {
  console.error(`Error: ${data}`);
});

child.on('close', (code) => {
  console.log(`Process exited with code ${code}`);
});

>> Uses only the streams.
>> Does not store everthing in memory
>> It is generally used for logs, video, processing, large file handling

# fork () : It is used to run an other node.js file

syntax:
----------- >
const { fork } = require('child_process');
const child = fork(modulePath, args, options);

parent.js:
----------- >
const { fork } = require('child_process');

const child = fork('child.js');

child.send({ message: 'Hello from parent' });

child.on('message', (msg) => {
  console.log('From child:', msg);
});

child.js
-------------- >
process.on('message', (msg) => {
  console.log('From parent:', msg);

  process.send({ message: 'Hello from child' });
});

>> it has Built-in IPC (Inter-Process Communication)
>> it is used for messagings



Node.js provides 4 child process methods: exec, execFile, spawn, and fork.
exec runs commands in a shell and buffers output, so it's good for small tasks.
execFile runs files directly without a shell, making it more secure and efficient.
spawn handles large data using streams and is suitable for real-time processing.
fork is used specifically for running Node.js scripts and supports IPC communication between processes.

fork : It is used when we need to do any large background task's,  
